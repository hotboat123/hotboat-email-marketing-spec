# Base de datos donde vivirán las tablas de email marketing (contacts, campaigns, etc.)
# Puede ser la misma Railway DB que ya tienes — se crean tablas nuevas sin tocar las existentes
DATABASE_URL=postgresql://postgres:PASSWORD@turntable.proxy.rlwy.net:48129/railway

# DB fuente de HotBoat (donde están all_appointments, leads, etc.)
# Si es la misma que DATABASE_URL, déjala en blanco y se usará DATABASE_URL automáticamente
HOTBOAT_DATABASE_URL=

SECRET_KEY=cambia-esto-en-produccion-genera-con-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=HotBoat <hola@hotboat.cl>
RESEND_WEBHOOK_SECRET=

FRONTEND_URL=http://localhost:3000

# WooCommerce REST API — para generar links de pago directo en emails de carrito abandonado
# Generar en: WooCommerce → Ajustes → Avanzado → REST API → Añadir clave (Lectura)
WOO_URL=https://hotboatchile.com
WOO_CK=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOO_CS=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
